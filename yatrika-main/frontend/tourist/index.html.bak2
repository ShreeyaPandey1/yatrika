                                   </div>
                               </div>`
                        }
                        
                        <div class="absolute top-4 right-4 space-y-2">
                            <button onclick="getUserLocation()" class="w-10 h-10 glass-card rounded-xl flex items-center justify-center hover-lift transition-all duration-300">
                                <i data-lucide="crosshair" class="w-4 h-4 text-primary-600"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="p-4 flex-grow space-y-4 relative z-10">
                    
                    <div class="animate-scale-in" style="animation-delay: 0.2s">
                        ${isActive
                            ? `<button onclick="handleEndJourney()" class="w-full bg-gradient-to-r from-orange-400 to-red-500 text-white font-bold py-4 px-6 rounded-2xl text-lg hover-lift shadow-2xl transform transition-all duration-300 animate-pulse-glow">
                                   <div class="flex items-center justify-center space-x-3">
