                        <div class="flex items-center space-x-3">
                            <div class="flex-shrink-0">
                                <i data-lucide="shield" class="w-5 h-5 text-primary-600 dark:text-primary-400"></i>
                            </div>
                            <p class="text-sm text-surface-700 dark:text-surface-300">Your data is encrypted and secure with Yatrika</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    `;
    lucide.createIcons();
}

