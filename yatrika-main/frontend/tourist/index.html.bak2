                    <div class="animate-slide-up" style="animation-delay: 0.4s">
                        <div class="glass-card p-4 rounded-2xl border-l-4 border-yellow-400 hover-lift transition-all duration-300">
                            <div class="flex items-start space-x-3">
                                <div class="w-10 h-10 bg-gradient-to-br from-yellow-100 to-yellow-200 rounded-xl flex items-center justify-center flex-shrink-0">
                                    <i data-lucide="cloud-rain" class="w-5 h-5 text-yellow-600"></i>
                                </div>
                                <div class="flex-1">
                                    <h3 class="font-semibold text-surface-800 dark:text-surface-200 text-sm mb-1">
                                        Weather Alert: Heavy Rain Expected
                                    </h3>
                                    <p class="text-xs text-surface-500 dark:text-surface-400 leading-relaxed">
                                        Gangtok area - Potential roadblocks on NH10. Stay safe and plan accordingly.
                                    </p>
                                </div>
                                <div class="w-2 h-2 bg-yellow-400 rounded-full animate-pulse flex-shrink-0 mt-2"></div>
                            </div>
                        </div>
                    </div>

                    <div class="animate-slide-up" style="animation-delay: 0.5s">
                        <div class="glass-card p-4 rounded-2xl hover-lift transition-all duration-300">
                            <div class="flex items-center justify-between mb-3">
                                <h3 class="font-semibold text-surface-800 dark:text-surface-200 text-sm">Emergency Services</h3>
                                <span class="text-xs text-surface-500 dark:text-surface-400">Gangtok</span>
                            </div>
                            <div class="grid grid-cols-3 gap-3">
                                <a href="tel:100" class="text-center p-3 bg-surface-50 dark:bg-surface-800 rounded-xl hover:bg-primary-50 dark:hover:bg-primary-900 transition-colors">
                                    <div class="w-8 h-8 bg-blue-100 dark:bg-blue-900 rounded-lg mx-auto mb-1 flex items-center justify-center">
                                        <span class="text-sm">🚔</span>
                                    </div>
                                    <p class="text-xs font-medium text-surface-600 dark:text-surface-400">Police</p>
                                    <p class="text-sm font-bold text-surface-800 dark:text-surface-200">100</p>
                                </a>
                                <a href="tel:102" class="text-center p-3 bg-surface-50 dark:bg-surface-800 rounded-xl hover:bg-red-50 dark:hover:bg-red-900 transition-colors">
                                    <div class="w-8 h-8 bg-red-100 dark:bg-red-900 rounded-lg mx-auto mb-1 flex items-center justify-center">
                                        <span class="text-sm">🚑</span>
                                    </div>
                                    <p class="text-xs font-medium text-surface-600 dark:text-surface-400">Ambulance</p>
                                    <p class="text-sm font-bold text-surface-800 dark:text-surface-200">102</p>
                                </a>
                                <a href="tel:101" class="text-center p-3 bg-surface-50 dark:bg-surface-800 rounded-xl hover:bg-orange-50 dark:hover:bg-orange-900 transition-colors">
                                    <div class="w-8 h-8 bg-orange-100 dark:bg-orange-900 rounded-lg mx-auto mb-1 flex items-center justify-center">
                                        <span class="text-sm">🚒</span>
