<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Yatrika - Tourist Safety App</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        primary: {
                            50: '#f0fdfa',
                            100: '#ccfbf1',
                            200: '#99f6e4',
                            300: '#5eedd8',
                            400: '#2dd4bf',
                            500: '#14b8a6',
                            600: '#0d9488',
                            700: '#0f766e',
                            800: '#115e59',
                            900: '#134e4a',
                            'dark': '#0f3d35',
                            'light': '#14b8a6',
                        },
                        accent: {
                            50: '#fef7ff',
                            100: '#fdeeff',
                            200: '#fcddff',
                            300: '#fab1ff',
                            400: '#f775ff',
                            500: '#ec39ff',
                            600: '#d818e7',
                            700: '#b70fbb',
                            800: '#971296',
                            900: '#7a1677',
                        },
                        surface: {
                            50: '#f8fafc',
                            100: '#f1f5f9',
                            200: '#e2e8f0',
                            300: '#cbd5e1',
                            400: '#94a3b8',
                            500: '#64748b',
                            600: '#475569',
                            700: '#334155',
                            800: '#1e293b',
                            900: '#0f172a',
                        },
                        background: {
                            'light': '#fefefe',
                            'dark': '#0f172a',
                        },
                        neutral: {
                            'text': '#64748b'
                        }
                    },
                    animation: {
                        'fade-in': 'fadeIn 0.6s ease-out',
                        'slide-up': 'slideUp 0.6s ease-out',
                        'slide-down': 'slideDown 0.6s ease-out',
                        'scale-in': 'scaleIn 0.4s ease-out',
                        'bounce-soft': 'bounceSoft 2s ease-in-out infinite',
                        'pulse-glow': 'pulseGlow 2s ease-in-out infinite',
                        'float': 'float 3s ease-in-out infinite',
                        'shimmer': 'shimmer 2s linear infinite',
                    },
                    backdropBlur: {
                        xs: '2px',
                    }
                }
            }
        }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    
    
    <link rel='stylesheet' href='https://unpkg.com/leaflet@1.9.4/dist/leaflet.css'/>
    <script src='https://unpkg.com/leaflet@1.9.4/dist/leaflet.js'></script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
            -webkit-tap-highlight-color: transparent;
            background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 50%, #f1f5f9 100%);
            min-height: 100vh;
        }
        
        .dark body {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #334155 100%);
        }
        
        #app-container {
            border-radius: 2.5rem;
            box-shadow: 
                0 25px 50px rgba(0,0,0,0.1),
                0 0 0 1px rgba(255,255,255,0.1),
                inset 0 1px 0 rgba(255,255,255,0.2);
            overflow: hidden;
            position: relative;
            backdrop-filter: blur(10px);
            background: rgba(255,255,255,0.95);
            border: 1px solid rgba(255,255,255,0.2);
        }
        
        .dark #app-container {
            background: rgba(15,23,42,0.95);
            border: 1px solid rgba(148,163,184,0.1);
            box-shadow: 
                0 25px 50px rgba(0,0,0,0.3),
                0 0 0 1px rgba(148,163,184,0.1),
                inset 0 1px 0 rgba(148,163,184,0.1);
        }
        
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { 
            background: rgba(148,163,184,0.1);
            border-radius: 10px; 
        }
        ::-webkit-scrollbar-thumb { 
            background: linear-gradient(135deg, #14b8a6, #0d9488);
            border-radius: 10px;
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.2);
        }
        ::-webkit-scrollbar-thumb:hover {
            background: linear-gradient(135deg, #0d9488, #0f766e);
        }
        
       
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px) scale(0.98); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }
        
        @keyframes slideUp {
            from { transform: translateY(30px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
        
        @keyframes slideDown {
            from { transform: translateY(-30px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
        
        @keyframes scaleIn {
            from { transform: scale(0.9); opacity: 0; }
            to { transform: scale(1); opacity: 1; }
        }
        
        @keyframes bounceSoft {
            0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
            40% { transform: translateY(-8px); }
            60% { transform: translateY(-4px); }
        }
        
        @keyframes pulseGlow {
            0%, 100% { 
                box-shadow: 0 0 20px rgba(20,184,166,0.3);
                transform: scale(1);
            }
            50% { 
                box-shadow: 0 0 30px rgba(20,184,166,0.5);
                transform: scale(1.02);
            }
        }
        
        @keyframes float {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-10px) rotate(2deg); }
        }
        
        @keyframes shimmer {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(100%); }
        }

        .btn-primary {
            background: linear-gradient(135deg, #14b8a6 0%, #0d9488 50%, #0f766e 100%);
            box-shadow: 
                0 10px 25px rgba(20,184,166,0.2),
                inset 0 1px 0 rgba(255,255,255,0.2);
            transition: all 0.3s ease;
        }
        
        .btn-primary:hover {
            background: linear-gradient(135deg, #0d9488 0%, #0f766e 50%, #115e59 100%);
            box-shadow: 
                0 15px 35px rgba(20,184,166,0.3),
                inset 0 1px 0 rgba(255,255,255,0.3);
            transform: translateY(-2px);
        }
        
        .btn-secondary {
            background: linear-gradient(135deg, #ec39ff 0%, #d818e7 50%, #b70fbb 100%);
            box-shadow: 
                0 10px 25px rgba(236,57,255,0.2),
                inset 0 1px 0 rgba(255,255,255,0.2);
        }
        
        
        .glass-card {
            background: rgba(255,255,255,0.8);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.3);
            box-shadow: 
                0 8px 32px rgba(0,0,0,0.1),
                inset 0 1px 0 rgba(255,255,255,0.4);
        }
        
        .dark .glass-card {
            background: rgba(30,41,59,0.8);
            border: 1px solid rgba(148,163,184,0.1);
            box-shadow: 
                0 8px 32px rgba(0,0,0,0.3),
                inset 0 1px 0 rgba(148,163,184,0.1);
        }
        
        .panic-button-active {
            background: linear-gradient(135deg, #ef4444, #dc2626, #b91c1c);
            animation: panicPulse 1.5s infinite;
        }
        
        @keyframes panicPulse {
            0% { 
                transform: scale(1);
                box-shadow: 0 0 20px rgba(239,68,68,0.5);
            }
            50% { 
                transform: scale(1.05);
                box-shadow: 0 0 40px rgba(239,68,68,0.8);
            }
            100% { 
                transform: scale(1);
                box-shadow: 0 0 20px rgba(239,68,68,0.5);
            }
        }

        
        @keyframes pulse {
            0% { 
                box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7); 
            }
            70% { 
                box-shadow: 0 0 0 10px rgba(16, 185, 129, 0); 
            }
            100% { 
                box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); 
            }
        }

        .destination-marker {
            transition: transform 0.2s ease;
        }
        
        .destination-marker:hover {
            transform: scale(1.1);
        }
        
        
        .tab-button {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            background: rgba(148,163,184,0.1);
            backdrop-filter: blur(8px);
        }
        
        .tab-button.active {
            background: linear-gradient(135deg, #14b8a6, #0d9488);
            box-shadow: 
                0 8px 25px rgba(20,184,166,0.3),
                inset 0 1px 0 rgba(255,255,255,0.2);
        }
        
        
        #map {
            border-radius: 1rem;
            border: 2px solid rgba(255,255,255,0.3);
            box-shadow: 
                0 20px 40px rgba(0,0,0,0.1),
                inset 0 1px 0 rgba(255,255,255,0.3);
        }
        
        .dark #map {
            border: 2px solid rgba(148,163,184,0.1);
            box-shadow: 
                0 20px 40px rgba(0,0,0,0.3),
                inset 0 1px 0 rgba(148,163,184,0.1);
        }
        
        /* mapboxgl-popup-content {
            border-radius: 12px;
            padding: 16px 20px;
            background: rgba(255,255,255,0.95);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.3);
            box-shadow: 0 20px 40px rgba(0,0,0,0.15);
        }
        
        } */ .leaflet-popup-content {
            border-radius: 12px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.1);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255,255,255,0.2);
        }
        
        .loading-shimmer {
            position: relative;
            overflow: hidden;
        }
        
        .loading-shimmer::after {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            bottom: 0;
            left: 0;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
            animation: shimmer 1.5s infinite;
        }
        
        
        .hover-lift {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .hover-lift:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.15);
        }
        
        
        .gradient-text {
            background: linear-gradient(135deg, #14b8a6, #0d9488, #ec39ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark transition-colors duration-300">
    <div id="app-container" class="h-screen w-full mx-auto max-w-lg flex flex-col bg-background-light dark:bg-background-dark"></div>
    <div id="bottom-nav-container"></div>
    
    
    <div class="fixed top-6 right-6 z-40 pointer-events-none">
        <div class="max-w-lg mx-auto flex justify-end pointer-events-auto">
            <button
                id="floating-panic-btn"
                onclick="handlePanic()"
                class="w-14 h-14 bg-gradient-to-br from-red-500 to-red-600 hover:from-red-600 hover:to-red-700 text-white font-bold rounded-full flex items-center justify-center transition-all duration-300 transform hover:scale-110 active:scale-95 shadow-2xl"
                title="Emergency Panic Button - Tap to alert authorities"
            >
                <i data-lucide="shield-alert" class="w-6 h-6"></i>
            </button>
        </div>
    </div>

    <div id="qr-modal" class="fixed inset-0 bg-black/80 z-50 flex-col items-center justify-center hidden">
        <div class="bg-white dark:bg-gray-800 p-8 rounded-2xl shadow-2xl text-center animate-fade-in w-11/12 max-w-sm">
            <h2 id="qr-modal-title" class="text-2xl font-bold text-gray-800 dark:text-white mb-2"></h2>
            <p id="qr-modal-subtitle" class="text-neutral-text dark:text-gray-300 mb-6"></p>
            <div id="qr-code-container" class="p-4 bg-white rounded-lg inline-block">
                <canvas id="qr-canvas"></canvas>
            </div>
            <p id="qr-modal-tx-label" class="text-sm text-gray-500 mt-4"></p>
            <p id="qr-modal-tx-hash" class="text-xs text-primary-light font-mono break-all mt-1"></p>
            <button onclick="hideQrModal()" class="mt-8 w-full bg-primary-light text-white font-bold py-3 px-4 rounded-lg hover:opacity-90 transition-opacity">
                Close
            </button>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrious/4.0.2/qrious.min.js"></script>

    <script>
    
   const API_URL = "http://localhost:5000/api"; 
        
    const ADMIN_APP_URL = "http://your-admin-app-url.com/login"; 
    
    // Leaflet - no token needed 
    let map;
    let userLocationMarker;
    
    window.debugMap = function() {
        console.log('=== MAP DEBUG INFO ===');
        console.log('mapboxgl available:', typeof mapboxgl !== 'undefined');
        console.log('map container exists:', !!document.getElementById('map'));
        console.log('map object:', !!map);
        console.log('current page:', state.currentPage);
        console.log('access token set:', !!mapboxgl.accessToken);
        if (document.getElementById('map')) {
            console.log('map container HTML:', document.getElementById('map').innerHTML);
        }
        console.log('=====================');
    };

    let destinationCount = 1;

    let state = {
        currentPage: 'splash',
        language: 'en',
        isDarkMode: true,
        currentUser: null,
        activeJourney: null,
        activeJourneyData: null, 
        itineraryDrafts: [],
        profile: null,
    };

    
    const translations = {
        en: { appName: "Yatrika", welcome: "Welcome", tagline: "Your Safety, Our Priority", selectLanguage: "Select Language", login: "Login", signup: "Sign Up", phone: "Phone Number", password: "Password", home: "Home", plan: "Plan", active: "Active Trip", account: "Account", panic: "PANIC", planNewTrip: "Plan New Trip", myTripDrafts: "My Trip Drafts", safetyScore: "Safety Score", startJourney: "Start Planned Journey", endJourney: "End Current Journey", activeJourney: "Active Journey", nextStop: "Next Stop", updateItinerary: "Update Itinerary", shareLocation: "Share Location", profileDetails: "Profile Details", familyMembers: "Family Members", addMember: "Add Member", emergencyContacts: "Emergency Contacts", settings: "Settings", voiceActivation: "Voice Activation", journeyActivation: "Journey Activation", selectDraft: "Select an Itinerary Draft", setDates: "Set Journey Dates", from: "From", to: "To", selectMembers: "Select Members", activateTrip: "Activate Trip", showQrCode: "Show Verification QR Code", qrCodeTitle: "Journey Activated!", qrCodeSubtitle: "Show this QR code to authorities for verification.", txHash: "Blockchain Transaction Hash", close: "Close", createNewTrip: "Create New Trip Plan", notifications: "Notifications", role: "I am a:", register: "Register", createAccount: "Create Account", fullName: "Full Name", email: "Email Address", confirmPassword: "Confirm Password", alreadyHaveAccount: "Already have an account?", signInHere: "Sign in here", createYourAccount: "Create Your Account", joinYatrika: "Join Yatrika today", enterFullName: "Enter your full name", enterEmail: "Enter your email address", enterPassword: "Enter your password", reenterPassword: "Re-enter your password", registrationSuccess: "Registration successful! Welcome to Yatrika", age: "Age", emergency: "Emergency Contact", enterEmergencyContact: "Emergency contact number", back: "Back", signInContinue: "Sign in to continue", sendOTP: "Send OTP", enterPhoneNumber: "Enter your phone number", agreeTerms: "By continuing, you agree to our Terms & Privacy Policy", phoneNumber: "Phone Number", createNewTrip: "Create New Trip", showQrCode: "Show QR Code", emergencyAlert: "EMERGENCY ALERT", emergencyActivated: "EMERGENCY ACTIVATED", callEmergency: "Call Emergency", callPolice: "Call Police", helpOnWay: "Help is on the way!", stayCalm: "Stay calm and stay safe", locationShared: "Your location has been shared with authorities" },
