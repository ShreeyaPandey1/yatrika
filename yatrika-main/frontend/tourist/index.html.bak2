    };

    
    const appContainer = document.getElementById('app-container');
    const navContainer = document.getElementById('bottom-nav-container');
    const getT = () => translations[state.language] || translations['en'];

    
    async function calculateSafetyScore(itinerary) {
        try {
            
            const destinations = itinerary.destinations || [];
            const currentHour = new Date().getHours();
            
            
            let totalScore = 0;
            let validScores = 0;

            for (const destination of destinations) {
                const destinationName = destination.city.toLowerCase();
                
                
                const touristData = {
                    current_area: destinationName,
                    deviation_km: 0, 
                    inactivity_minutes: 0, 
                    current_hour: currentHour
                };

                try {
                    
                    const aiUrls = [
                        'http://localhost:8000/calculate-score/',
                        'https://tourchain-ai.onrender.com/calculate-score/'
                    ];

                    let response;
                    for (const url of aiUrls) {
                        try {
                            response = await fetch(url, {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json',
                                },
                                body: JSON.stringify(touristData)
                            });
                            if (response.ok) break;
                        } catch (e) {
                            continue; 
                        }
                    }

                    if (response && response.ok) {
                        const result = await response.json();
                        totalScore += result.safety_score;
                        validScores++;
                    } else {
                        throw new Error('AI service not available');
                    }
                } catch (error) {
                    console.warn(`Could not calculate safety score for ${destinationName}:`, error);
                    
                    const defaultScore = getDefaultSafetyScore(destinationName);
                    totalScore += defaultScore;
                    validScores++;
                }
            }

            
            if (validScores === 0) {
                return 8.0; 
            }

            
            return Math.round((totalScore / validScores) * 10) / 10;
        } catch (error) {
            console.error('Error calculating safety score:', error);
            return 8.0; 
        }
    }

   
    function getDefaultSafetyScore(destinationName) {
        const safePlaces = ['park', 'museum', 'temple', 'monument', 'garden', 'mall', 'restaurant'];
        const moderatePlaces = ['market', 'station', 'airport', 'bus', 'train'];
        const riskyPlaces = ['alley', 'dark', 'isolated', 'remote'];

        const name = destinationName.toLowerCase();
        
        if (safePlaces.some(place => name.includes(place))) {
            return 9.0;
        } else if (moderatePlaces.some(place => name.includes(place))) {
            return 7.5;
        } else if (riskyPlaces.some(place => name.includes(place))) {
            return 6.0;
        } else {
            return 8.0; 
        }
    }

    
    function updateDraftSafetyScore(draftId, score) {
        const scoreElement = document.querySelector(`[data-draft-id="${draftId}"] .safety-score`);
        if (scoreElement) {
            const scoreColor = score >= 8 ? 'text-green-500' : 
                              score >= 6 ? 'text-yellow-500' : 'text-red-500';
            scoreElement.innerHTML = score;
            scoreElement.className = `text-xl font-bold ${scoreColor}`;
        }
    }

   
    function initializeMap() {
        if (!document.getElementById('map')) {
            console.log('Map container not found');
            return;
        }
        
        if (typeof mapboxgl === 'undefined') {
            console.error('Mapbox GL JS not loaded');
            showMapFallback();
            return;
        }
        
        console.log('Initializing Mapbox map...');
        try {
            map = new mapboxgl.Map({
                container: 'map',
                style: 'mapbox://styles/mapbox/streets-v12',
                center: [88.3639, 22.5726], 
                zoom: 12,
                attributionControl: false
            });
            
            console.log('Mapbox map created successfully');

          
            map.addControl(new mapboxgl.NavigationControl(), 'top-right');
            
           
            const geolocate = new mapboxgl.GeolocateControl({
                positionOptions: {
                    enableHighAccuracy: true
                },
                trackUserLocation: true,
                showUserHeading: true
            });
            
            map.addControl(geolocate, 'top-right');
            
            
            map.on('load', function() {
                getUserLocation();
                addEmergencyServices(); 
                
                
                setTimeout(() => {
                    geolocate.trigger();
                }, 1000);
            });
            
            
            map.on('error', function(e) {
                console.warn('Map error:', e);
                showMapFallback();
            });
            
        } catch (error) {
            console.error('Failed to initialize map:', error);
            showMapFallback();
        }
    }
    
    
    window.testMap = function() { console.log('map ok'); }
    
    
    function showMapFallback() {
        const mapContainer = document.getElementById('map');
        if (mapContainer) {
            mapContainer.innerHTML = `
                <div class="w-full h-full bg-gradient-to-br from-blue-100 to-green-100 dark:from-gray-700 dark:to-gray-800 flex items-center justify-center text-center rounded-lg border-2 border-dashed border-gray-300 dark:border-gray-600">
                    <div class="p-4">
                        <i data-lucide="map-pin" class="w-12 h-12 mx-auto mb-3 text-primary-light"></i>
                        <p class="text-sm font-medium text-gray-700 dark:text-gray-300">Interactive Map Loading...</p>
                        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Preparing your location view</p>
                        <button onclick="initializeMap()" class="mt-3 px-4 py-2 bg-primary-light text-white text-xs rounded-lg hover:opacity-90">
                            Retry Map Load
                        </button>
                    </div>
                </div>
            `;
            lucide.createIcons();
        }
    }

    
    function getUserLocation() {
        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(
                function(position) {
                    const lat = position.coords.latitude;
                    const lng = position.coords.longitude;
                    
                   
                    if (map) {
                        map.setView([lat, lng], 15);
                        
                        
                        if (userLocationMarker) {
                            userLocationMarker.remove();
                        }
                        
                        userLocationMarker = L.marker([lat, lng])
                        .bindPopup('<strong>Your Location</strong>')
                        .addTo(map);
                    }
                },
                function(error) {
                    console.warn('Geolocation error:', error);
                    
                    if (map) {
                        map.setView([22.5726, 88.3639], 12);
                    }
                }
            );
        }
    }

    
    function addJourneyRoute(journey) {
        if (!map || !journey) return;
        
        
        if (journey.itinerary && journey.itinerary.destinations) {
            journey.itinerary.destinations.forEach((destination, index) => {
               
                const lng = 88.3639 + (Math.random() - 0.5) * 0.1;
                const lat = 22.5726 + (Math.random() - 0.5) * 0.1;
                
                L.marker([lat, lng])
                .bindPopup(`<strong>${destination.city}</strong><br>${destination.places.join(', ')}`)
                .addTo(map);
            });
        }
    }

    function updateMapForActiveJourney() {
        if (!map || !state.activeJourney) return;
        
        addJourneyRoute(state.activeJourney);
        
        
    }
    
    
    function addEmergencyServices() {
        if (!map) return;
        
        
        const emergencyServices = [
            { name: 'Police Station', type: 'police', coords: [88.3639, 22.5726], phone: '100' },
            { name: 'Hospital', type: 'hospital', coords: [88.3700, 22.5780], phone: '102' },
            { name: 'Fire Station', type: 'fire', coords: [88.3580, 22.5680], phone: '101' }
        ];
        
        emergencyServices.forEach(service => {
            const color = service.type === 'police' ? '#3b82f6' : 
                         service.type === 'hospital' ? '#ef4444' : '#f59e0b';
            
            L.marker([service.coords[1], service.coords[0]])
            .bindPopup(`<strong>${service.name}</strong><br>Emergency: ${service.phone}<br><button onclick="window.open('tel:${service.phone}')" style="margin-top:4px;padding:2px 8px;background:#ef4444;color:white;border:none;border-radius:4px;cursor:pointer">Call Now</button>`)
            .addTo(map);
        });
    }

    async function apiRequest(endpoint, method = "GET", body = null) {
    try {
        const fullUrl = `${API_URL}${endpoint}`;
        console.log('Making API request to:', fullUrl);
        const options = { method, headers: { "Content-Type": "application/json" } };
        if (state.currentUser && state.currentUser.token) {
            options.headers['Authorization'] = `Bearer ${state.currentUser.token}`;
        }
        if (body) {
            options.body = JSON.stringify(body);
            console.log('Request body:', options.body);
        }
        console.log('Request options:', options);
        
        const res = await fetch(fullUrl, options);
        console.log('Response status:', res.status);
        console.log('Response ok:', res.ok);
        
        if (!res.ok) {
            const errorText = await res.text();
            console.error('API Error response:', errorText);
            throw new Error(errorText || `HTTP ${res.status}`);
        }

        const text = await res.text();
        return text ? JSON.parse(text) : {}; 

    } catch (err) {
        console.error('API Request Failed:', err);
        throw err;
    }
}

    function showQrModal(journeyData) {
        const t = getT();
        document.getElementById('qr-modal-title').innerText = t.qrCodeTitle;
        document.getElementById('qr-modal-subtitle').innerText = t.qrCodeSubtitle;
        document.getElementById('qr-modal-tx-label').innerText = t.txHash;
        document.getElementById('qr-modal-tx-hash').innerText = journeyData.txHash;
        document.querySelector('#qr-modal button').innerText = t.close;

        const qrCanvas = document.getElementById('qr-canvas');
        new QRious({
            element: qrCanvas,
            value: `${window.location.origin}/verify?token=${journeyData.qrCodeToken}`,
            size: 200,
            padding: 10,
        });

        const modal = document.getElementById('qr-modal');
        modal.classList.remove('hidden');
        modal.classList.add('flex');
    }

    function hideQrModal() {
        const modal = document.getElementById('qr-modal');
        modal.classList.remove('flex');
        modal.classList.add('hidden');
    }

    
    function renderBottomNav() {
        if (!state.currentUser) {
            navContainer.innerHTML = '';
            return;
        }
        const t = getT();
        const navItems = [
            { id: 'home', icon: 'home', label: t.home },
            { id: 'plan', icon: 'map', label: t.plan },
            { id: 'active', icon: 'play-circle', label: t.active },
            { id: 'account', icon: 'user', label: t.account },
        ];

        const panicButton = `
            <div class="absolute -top-8 left-1/2 -translate-x-1/2">
                <button
                    id="panic-button"
                    onclick="handlePanic()"
                    title="${t.panic}"
                    class="w-16 h-16 bg-gradient-to-br from-red-500 to-red-600 hover:from-red-600 hover:to-red-700 text-white font-bold rounded-full flex items-center justify-center transition-all duration-300 transform hover:scale-110 active:scale-95 shadow-2xl animate-pulse-glow"
                >
                    <i data-lucide="shield-alert" class="w-7 h-7"></i>
                </button>
            </div>
        `;

        navContainer.innerHTML = `
            <div class="fixed bottom-0 left-0 right-0 z-30 p-4 max-w-lg mx-auto">
                <div class="relative glass-card rounded-3xl p-3 shadow-2xl border border-white/20">
                    <div class="flex justify-around items-center">
                        ${navItems.map(item => `
                            <button
                                onclick="showPage('${item.id}')"
                                class="flex flex-col items-center justify-center flex-grow h-14 rounded-2xl transition-all duration-300 transform hover:scale-105 active:scale-95 tab-button ${
                                    state.currentPage === item.id 
                                        ? 'active text-white' 
                                        : 'text-surface-500 dark:text-surface-400 hover:text-primary-600 dark:hover:text-primary-400'
                                }"
                            >
                                <div class="relative">
                                    <i data-lucide="${item.icon}" class="w-5 h-5"></i>
                                    ${state.currentPage === item.id ? '<div class="absolute -inset-1 bg-white/20 rounded-lg blur-sm"></div>' : ''}
                                </div>
                                <span class="text-xs mt-1 font-medium">${item.label}</span>
                            </button>
                        `).join('')}
                    </div>
                    ${panicButton}
                </div>
            </div>
        `;
        lucide.createIcons();
    }

