        const isActive = state.activeJourney;

        const mainActionButton = isActive
            ? `<button onclick="handleEndJourney()" class="w-full bg-orange-500 text-white font-bold py-4 px-4 rounded-xl text-lg hover:opacity-90 transition-opacity transform active:scale-95">${t.endJourney}</button>`
            : `<button onclick="showPage('active')" class="w-full bg-primary-light text-white font-bold py-4 px-4 rounded-xl text-lg hover:opacity-90 transition-opacity transform active:scale-95">${t.startJourney}</button>`;

        appContainer.innerHTML = `
