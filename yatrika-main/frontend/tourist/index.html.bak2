                        </div>
                    </div>
                </div>
            </div>
        `;
        lucide.createIcons();
        
        
        initializeMap();
        
        
        setTimeout(() => {
            if (!map) {
                console.log('Retrying map initialization...');
                initializeMap();
            }
            if (isActive && map) {
                updateMapForActiveJourney();
            }
        }, 1000);
    }


function renderPlanActivationPage() {
    const t = getT();
    const members = state.profile?.familyMembers || [];

    
    if (!state.itineraryDrafts || state.itineraryDrafts.length === 0) {
        
        appContainer.innerHTML = `
            <div class="flex flex-col items-center justify-center h-full p-8 text-center">
                <i data-lucide="clipboard-list" class="w-12 h-12 text-gray-400 mb-4"></i>
                <h2 class="text-xl font-bold text-gray-800 dark:text-white mb-2">No Trip Plans Found</h2>
                <p class="text-neutral-text dark:text-gray-400 mb-6">Go to the 'Plan' tab and create an itinerary before activating a journey.</p>
                <button onclick="showPage('plan')" class="bg-primary-light text-white font-bold py-3 px-6 rounded-lg">${t.plan}</button>
            </div>
        `;
        lucide.createIcons();
        return; 
    }

    
    appContainer.innerHTML = `
        <div class="flex-grow p-4 overflow-y-auto pb-24">
            <h2 class="text-2xl font-bold text-gray-800 dark:text-white mb-6">${t.journeyActivation}</h2>

            <div class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-lg space-y-5">
                <div>
                    <label for="draft-select" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">${t.selectDraft}</label>
                    <select id="draft-select" class="w-full p-3 bg-gray-100 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-primary-light focus:border-primary-light">
                        ${state.itineraryDrafts.map(draft =>
                            `<option value="${draft._id}">${draft.name || 'Untitled Trip'} (${draft.destinations?.length || 0} Stops)</option>`
                        ).join('')}
                    </select>
                </div>

                <div class="flex space-x-4">
                    <div class="flex-1">
                        <label for="start-date" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">${t.from}</label>
                        <input type="date" id="start-date" value="${new Date().toISOString().substring(0, 10)}" class="w-full p-3 bg-gray-100 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg">
                    </div>
                    <div class="flex-1">
                        <label for="end-date" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">${t.to}</label>
                        <input type="date" id="end-date" value="${new Date(Date.now() + 86400000 * 7).toISOString().substring(0, 10)}" class="w-full p-3 bg-gray-100 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg">
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">${t.selectMembers}</label>
                    <div class="space-y-2 max-h-40 overflow-y-auto p-2 bg-gray-50 dark:bg-gray-700 rounded-lg">
                        <div class="flex items-center">
                            <input type="checkbox" id="member-self" name="member-self" checked disabled class="w-4 h-4 text-primary-light rounded border-gray-300 dark:border-gray-600">
                            <label for="member-self" class="ml-2 text-sm font-medium text-gray-900 dark:text-gray-200">${state.profile?.fullName || 'Me (Tourist)'}</label>
                        </div>
                        ${members.map(member => `
                            <div class="flex items-center">
                                <input type="checkbox" id="member-${member._id}" name="member-${member._id}" class="member-checkbox w-4 h-4 text-primary-light rounded border-gray-300 dark:border-gray-600">
                                <label for="member-${member._id}" class="ml-2 text-sm font-medium text-gray-900 dark:text-gray-200">${member.fullName}</label>
                            </div>
                        `).join('')}
                    </div>
                </div>

                <button onclick="handleActivateTrip()" class="w-full bg-primary-light text-white font-bold py-4 px-4 rounded-lg text-lg hover:opacity-90 transition-opacity transform active:scale-95">
                    ${t.activateTrip}
                </button>
            </div>
        </div>
    `;
    lucide.createIcons();
}

    let placeCounts = {};
    function addDestinationBlock() {
    destinationCount++;
    const container = document.getElementById('destinations-container');
    container.insertAdjacentHTML('beforeend', renderDestinationBlock(destinationCount));
    lucide.createIcons();
}



function renderDestinationBlock(id) {
    return `
        <div id="destination-${id}" class="p-4 border border-gray-200 dark:border-gray-700 rounded-lg space-y-3 bg-gray-50 dark:bg-gray-900/50">
            <div class="flex justify-between items-center">
                <label class="text-md font-semibold text-primary-light">Destination City #${id}</label>
                ${id > 1 ? `<button type="button" onclick="this.parentElement.parentElement.remove()" class="text-red-500"><i data-lucide="x" class="w-5 h-5"></i></button>` : ''}
            </div>
            
            <input type="text" placeholder="Enter Destination City (e.g., Delhi)" class="destination-city-input w-full p-2 bg-white dark:bg-gray-700 rounded-md">
            
            <h4 class="text-sm font-semibold text-gray-600 dark:text-gray-300 pt-2">Places to Visit in this City</h4>
            <div class="places-container space-y-2">
                ${addPlaceBlock(id, true)}
            </div>
            <button type="button" onclick="addPlaceToUI(${id})" class="w-full text-sm bg-indigo-100 dark:bg-indigo-900/50 text-indigo-600 dark:text-indigo-300 font-semibold py-1.5 px-3 rounded-md">
                Add another place
            </button>
        </div>
    `;
}

function addPlaceBlock(destinationId, isFirst = false) {
    const placeHTML = `
        <div class="flex items-center space-x-2">
            <input type="text" placeholder="Place Name" class="place-name-input flex-grow min-w-0 p-2 bg-white dark:bg-gray-700 rounded-md">
            <input type="text" placeholder="Notes (Optional)" class="place-notes-input flex-grow min-w-0 p-2 bg-white dark:bg-gray-700 rounded-md">
            ${!isFirst ? `<button type="button" onclick="this.parentElement.remove()" class="p-2 text-red-500 hover:bg-red-100 dark:hover:bg-red-900/50 rounded-full"><i data-lucide="minus-circle" class="w-5 h-5"></i></button>` : '<div class="w-9 h-9"></div>'}
        </div>
    `;
    return placeHTML;
}

function addPlaceToUI(destinationId) {
    const placesContainer = document.querySelector(`#destination-${destinationId} .places-container`);
    const newPlaceHTML = addPlaceBlock(destinationId, false);
    placesContainer.insertAdjacentHTML('beforeend', newPlaceHTML);
    lucide.createIcons(); 
}


    function removeDestinationBlock(id) {
        document.getElementById(`destination-${id}`).remove();
    }

    function renderNewItineraryPlanPage() {
    const t = getT();
    destinationCount = 1; 
    appContainer.innerHTML = `
        <div class="flex-grow p-4 overflow-y-auto pb-20">
            <h2 class="text-2xl font-bold text-gray-800 dark:text-white mb-6">${t.createNewTrip}</h2>
            <div id="itinerary-form" class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-lg space-y-4">
                
                <div>
                    <label for="trip-name" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Trip Name</label>
                    <input type="text" id="trip-name" placeholder="E.g., Golden Triangle Tour" class="w-full p-3 bg-gray-100 dark:bg-gray-700 rounded-lg">
                </div>

                <div>
                    <label for="starting-city" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Your Current City</label>
                    <input type="text" id="starting-city" placeholder="E.g., Kolkata" class="w-full p-3 bg-gray-100 dark:bg-gray-700 rounded-lg">
                </div>
                
                <h3 class="font-bold text-lg text-primary-dark dark:text-white pt-2">Destination Cities</h3>
                <div id="destinations-container" class="space-y-4">
                    ${renderDestinationBlock(1)}
                </div>

                <button onclick="addDestinationBlock()" class="w-full bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 font-bold py-2 px-4 rounded-lg flex items-center justify-center">
                    <i data-lucide="map-pin" class="w-5 h-5 mr-2"></i>
                    Add Another Destination City
                </button>
                
                <button onclick="handleSaveItinerary()" class="w-full bg-primary-light text-white font-bold py-3 px-4 rounded-lg mt-6">
                    Save Itinerary Draft
                </button>
            </div>
        </div>

    `;
    lucide.createIcons();
}

    async function renderPlanPage() {
        const t = getT();
       
        try {
            const draftsData = await apiRequest('/itineraries');
            state.itineraryDrafts = draftsData.drafts || [];
        } catch (err) {
            console.error("Could not fetch itineraries from API, using localStorage fallback:", err);
            
            const localDrafts = JSON.parse(localStorage.getItem('tourchain-itineraries') || '[]');
            state.itineraryDrafts = localDrafts;
        }

        
        for (let draft of state.itineraryDrafts) {
            if (!draft.safetyScore) {
                
                draft.safetyScore = 'loading';
                
                calculateSafetyScore(draft).then(score => {
                    draft.safetyScore = score;
                    
                    updateDraftSafetyScore(draft._id, score);
                });
            }
        }

        appContainer.innerHTML = `
            <div class="relative flex-grow overflow-hidden">
                <div class="absolute inset-0 opacity-10">
                    <div class="absolute top-16 right-8 w-24 h-24 bg-primary-300 rounded-full animate-float"></div>
                    <div class="absolute bottom-32 left-12 w-32 h-32 bg-accent-300 rounded-full animate-float" style="animation-delay: 1.5s"></div>
                </div>
                
                <div class="relative p-6 overflow-y-auto h-full z-10">
                    
                    <div class="text-center mb-8 animate-slide-down">
                        <div class="w-16 h-16 bg-gradient-to-br from-primary-400 to-accent-400 rounded-2xl mx-auto mb-4 flex items-center justify-center">
                            <i data-lucide="map" class="w-8 h-8 text-white"></i>
                        </div>
                        <h2 class="text-2xl font-bold gradient-text mb-2">${t.myTripDrafts}</h2>
                        <p class="text-sm text-surface-500 dark:text-surface-400">Plan your next adventure</p>
                    </div>

                    
                    <button onclick="showPage('newItinerary')" class="w-full bg-gradient-to-r from-accent-500 to-primary-600 hover:from-accent-600 hover:to-primary-700 text-white font-semibold py-4 px-6 rounded-2xl mb-8 flex items-center justify-center transition-all duration-300 transform hover:scale-105 hover:shadow-lg animate-scale-in" style="animation-delay: 0.1s">
                        <div class="w-10 h-10 bg-white/20 rounded-xl flex items-center justify-center mr-3">
                            <i data-lucide="plus" class="w-5 h-5"></i>
                        </div>
                        ${t.createNewTrip}
                    </button>

                    <div class="space-y-4 animate-fade-in" style="animation-delay: 0.2s">
                        ${state.itineraryDrafts.length > 0 ? state.itineraryDrafts.map((draft, index) => {
                            let safetyScore, scoreColor, scoreBgColor, scoreIcon;
                            
                            if (draft.safetyScore === 'loading') {
                                safetyScore = '🔄';
                                scoreColor = 'text-primary-600';
                                scoreBgColor = 'bg-primary-100 dark:bg-primary-900';
                                scoreIcon = 'loader-2';
                            } else if (typeof draft.safetyScore === 'number') {
                                safetyScore = draft.safetyScore;
                                if (draft.safetyScore >= 8) {
                                    scoreColor = 'text-green-600';
                                    scoreBgColor = 'bg-green-100 dark:bg-green-900';
                                    scoreIcon = 'shield-check';
                                } else if (draft.safetyScore >= 6) {
                                    scoreColor = 'text-yellow-600';
                                    scoreBgColor = 'bg-yellow-100 dark:bg-yellow-900';
                                    scoreIcon = 'alert-triangle';
                                } else {
                                    scoreColor = 'text-red-600';
                                    scoreBgColor = 'bg-red-100 dark:bg-red-900';
                                    scoreIcon = 'shield-x';
                                }
                            } else {
                                safetyScore = 'N/A';
                                scoreColor = 'text-surface-400';
                                scoreBgColor = 'bg-surface-100 dark:bg-surface-800';
                                scoreIcon = 'help-circle';
                            }
                            
                            return `
                            <div data-draft-id="${draft._id}" class="glass-card p-6 rounded-2xl border border-primary-200 dark:border-primary-800 hover-lift transition-all duration-300 group animate-slide-up" style="animation-delay: ${0.3 + index * 0.1}s">
                                <div class="flex justify-between items-start">
                                    <div class="flex-1">
                                        <div class="flex items-center space-x-3 mb-3">
                                            <div class="w-12 h-12 bg-gradient-to-br from-primary-100 to-accent-100 dark:from-primary-900 dark:to-accent-900 rounded-xl flex items-center justify-center">
                                                <i data-lucide="map-pin" class="w-6 h-6 text-primary-600 dark:text-primary-400"></i>
                                            </div>
                                            <div>
                                                <h3 class="text-lg font-bold text-surface-800 dark:text-surface-200">${draft.name}</h3>
                                                <p class="text-sm text-surface-500 dark:text-surface-400">${draft.destinations.map(d => d.city).join(', ')}</p>
                                            </div>
                                        </div>
                                        
                                        <div class="flex flex-wrap gap-2 mb-4">
                                            ${draft.destinations.slice(0, 3).map(dest => `
                                                <div class="px-3 py-1 bg-surface-100 dark:bg-surface-800 rounded-full text-xs text-surface-600 dark:text-surface-400">
                                                    📍 ${dest.city}
                                                </div>
                                            `).join('')}
                                            ${draft.destinations.length > 3 ? `<div class="px-3 py-1 bg-surface-100 dark:bg-surface-800 rounded-full text-xs text-surface-600 dark:text-surface-400">+${draft.destinations.length - 3} more</div>` : ''}
                                        </div>
                                    </div>
                                    
                                    <div class="flex flex-col items-end space-y-3">
                                        <div class="text-center">
                                            <div class="w-16 h-16 ${scoreBgColor} rounded-2xl flex flex-col items-center justify-center mb-2">
                                                <i data-lucide="${scoreIcon}" class="w-5 h-5 ${scoreColor} ${draft.safetyScore === 'loading' ? 'animate-spin' : ''}"></i>
                                                <span class="safety-score text-sm font-bold ${scoreColor}">${safetyScore}</span>
                                            </div>
                                            <p class="text-xs text-surface-500 dark:text-surface-400">${t.safetyScore}</p>
                                        </div>
                                        
                                        <button onclick="renderEditItineraryPage('${draft._id}')" class="w-10 h-10 glass-card rounded-xl flex items-center justify-center text-surface-600 dark:text-surface-400 hover:text-primary-600 dark:hover:text-primary-400 hover-lift transition-all duration-300 group-hover:scale-110">
                                            <i data-lucide="edit" class="w-5 h-5"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        `;
                        }).join('') : `
                            <div class="text-center py-16 animate-fade-in">
                                <div class="w-24 h-24 bg-gradient-to-br from-primary-100 to-accent-100 dark:from-primary-900 dark:to-accent-900 rounded-3xl mx-auto mb-6 flex items-center justify-center">
                                    <i data-lucide="map" class="w-12 h-12 text-surface-400"></i>
                                </div>
                                <h3 class="text-lg font-semibold text-surface-600 dark:text-surface-400 mb-2">No Trip Drafts Yet</h3>
                                <p class="text-surface-500 dark:text-surface-500 mb-6">Start planning your next adventure</p>
                                <button onclick="showPage('newItinerary')" class="bg-gradient-to-r from-primary-500 to-accent-500 hover:from-primary-600 hover:to-accent-600 text-white font-medium py-3 px-6 rounded-xl transition-all duration-300 transform hover:scale-105">
                                    <div class="flex items-center space-x-2">
                                        <i data-lucide="plus" class="w-4 h-4"></i>
                                        <span>Create Your First Trip</span>
                                    </div>
                                </button>
                            </div>
                        `}
                    </div>
                </div>
            </div>
        `;
        lucide.createIcons();
    }

    function renderDemoMapPage() {
        const t = getT();
        
        appContainer.innerHTML = `
            <div class="flex flex-col h-full relative overflow-hidden">
                
                <header class="relative p-4 flex justify-between items-center glass-card border-b border-white/10 backdrop-blur-md z-10">
                    <div class="flex items-center space-x-3">
                        <div class="w-10 h-10 bg-gradient-to-br from-primary-400 to-accent-400 rounded-xl flex items-center justify-center">
                            <span class="text-white text-lg">🗺️</span>
                        </div>
                        <div>
                            <h1 class="text-lg font-bold gradient-text">Yatrika Map</h1>
                            <p class="text-xs text-surface-500 dark:text-surface-400">Interactive Demo</p>
                        </div>
                    </div>
                    <button onclick="showPage('splash')" class="w-10 h-10 glass-card rounded-xl flex items-center justify-center text-surface-600 hover:text-primary-600 hover-lift transition-all duration-300">
                        <i data-lucide="x" class="w-5 h-5"></i>
                    </button>
                </header>

                <div class="relative flex-1 p-4">
                    <div class="relative h-full">
                        <div id="map" class="w-full h-full rounded-2xl shadow-2xl"></div>
                        
                        <div class="absolute top-4 left-4 glass-card px-4 py-2 rounded-full animate-pulse-glow">
                            <div class="flex items-center space-x-2">
                                <div class="w-2 h-2 bg-primary-400 rounded-full animate-pulse"></div>
                                <span class="text-xs font-medium text-surface-700 dark:text-surface-300">
                                    Demo Mode Active
                                </span>
                            </div>
                        </div>
                        
                        <div class="absolute top-4 right-4 space-y-2">
                            <button class="w-10 h-10 glass-card rounded-xl flex items-center justify-center hover-lift transition-all duration-300" onclick="getUserLocation()">
                                <i data-lucide="crosshair" class="w-5 h-5 text-primary-600"></i>
                            </button>
                        </div>
                        
                        <div id="map-loading" class="absolute inset-0 glass-card rounded-2xl flex items-center justify-center">
                            <div class="text-center animate-fade-in">
                                <div class="w-16 h-16 bg-gradient-to-br from-primary-400 to-accent-400 rounded-2xl mx-auto mb-4 flex items-center justify-center animate-bounce-soft">
                                    <i data-lucide="map-pin" class="w-8 h-8 text-white"></i>
                                </div>
                                <p class="text-sm font-medium text-surface-600 dark:text-surface-400">Loading Interactive Map...</p>
                                <div class="mt-2 w-32 h-1 bg-surface-200 dark:bg-surface-700 rounded-full mx-auto overflow-hidden">
                                    <div class="h-full bg-gradient-to-r from-primary-400 to-accent-400 rounded-full animate-shimmer"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="p-4 space-y-4">
                    <div class="grid grid-cols-2 gap-3">
                        <div class="glass-card p-4 rounded-2xl hover-lift transition-all duration-300">
                            <div class="w-8 h-8 bg-gradient-to-br from-primary-100 to-primary-200 rounded-lg mb-2 flex items-center justify-center">
                                <span class="text-sm">🛡️</span>
                            </div>
                            <h3 class="font-semibold text-surface-800 dark:text-surface-200 text-sm mb-1">Safety Zones</h3>
                            <p class="text-xs text-surface-500 dark:text-surface-400">Real-time monitoring</p>
                        </div>
                        
                        <div class="glass-card p-4 rounded-2xl hover-lift transition-all duration-300">
                            <div class="w-8 h-8 bg-gradient-to-br from-accent-100 to-accent-200 rounded-lg mb-2 flex items-center justify-center">
                                <span class="text-sm">🚨</span>
                            </div>
                            <h3 class="font-semibold text-surface-800 dark:text-surface-200 text-sm mb-1">Emergency</h3>
                            <p class="text-xs text-surface-500 dark:text-surface-400">Quick access help</p>
                        </div>
                    </div>
                    
                    <button onclick="showPage('languageSelect')" class="w-full btn-primary text-white font-semibold py-4 px-6 rounded-2xl text-sm shadow-lg hover-lift transform transition-all duration-300">
                        <div class="flex items-center justify-center space-x-2">
                            <span>Experience Full Yatrika</span>
                            <i data-lucide="arrow-right" class="w-4 h-4"></i>
                        </div>
                    </button>
                </div>
                
                <div class="absolute top-0 left-0 w-32 h-32 bg-primary-200 rounded-full blur-3xl opacity-20 animate-float"></div>
                <div class="absolute bottom-0 right-0 w-40 h-40 bg-accent-200 rounded-full blur-3xl opacity-20 animate-float" style="animation-delay: 1.5s"></div>
            </div>
        `;
        
        lucide.createIcons();
        
        
        setTimeout(() => {
            initializeMap();
            
            setTimeout(() => {
                const loading = document.getElementById('map-loading');
                if (loading) {
                    loading.style.opacity = '0';
                    loading.style.transform = 'scale(0.9)';
                    setTimeout(() => loading.remove(), 300);
                }
            }, 2000);
        }, 100);
    }

    function renderActivePage() {
        const t = getT();

        if (!state.activeJourney) {
            renderPlanActivationPage();
            return;
        }

        const journey = state.activeJourney;

        appContainer.innerHTML = `
            <div class="relative flex-grow overflow-hidden">
            
                <div class="absolute inset-0 opacity-10">
                    <div class="absolute top-20 right-8 w-28 h-28 bg-primary-300 rounded-full animate-float"></div>
                    <div class="absolute bottom-40 left-12 w-20 h-20 bg-accent-300 rounded-full animate-float" style="animation-delay: 1s"></div>
                </div>
                
                <div class="relative p-6 overflow-y-auto h-full z-10">
                
                    <div class="text-center mb-6 animate-slide-down">
                        <div class="w-16 h-16 bg-gradient-to-br from-primary-400 to-accent-400 rounded-2xl mx-auto mb-4 flex items-center justify-center">
                            <i data-lucide="compass" class="w-8 h-8 text-white"></i>
                        </div>
                        <h2 class="text-2xl font-bold gradient-text mb-2">${t.activeJourney}</h2>
                        <p class="text-sm text-surface-500 dark:text-surface-400">Track your current adventure</p>
                    </div>

                    <div class="glass-card p-4 rounded-3xl border border-primary-200 dark:border-primary-800 mb-6 animate-scale-in" style="animation-delay: 0.05s">
                        <div class="flex items-center space-x-3 mb-4">
                            <div class="w-10 h-10 bg-gradient-to-br from-blue-100 to-blue-200 dark:from-blue-900 dark:to-blue-800 rounded-xl flex items-center justify-center">
                                <i data-lucide="map-pin" class="w-5 h-5 text-blue-600 dark:text-blue-400"></i>
                            </div>
                            <h3 class="text-lg font-bold text-surface-800 dark:text-surface-200">Your Journey Map</h3>
                        </div>
                        <div id="journey-map" class="w-full h-64 rounded-2xl bg-surface-100 dark:bg-surface-800 border border-surface-200 dark:border-surface-700"></div>
                        <div class="mt-3 text-center">
                            <button onclick="centerMapOnCurrentLocation()" class="px-4 py-2 bg-blue-500 hover:bg-blue-600 text-white rounded-full text-sm font-medium transition-colors">
                                <i data-lucide="crosshair" class="w-4 h-4 inline mr-1"></i>
                                Center on Me
                            </button>
                        </div>
                    </div>

                    
                    <div class="glass-card p-6 rounded-3xl border border-primary-200 dark:border-primary-800 mb-6 animate-scale-in" style="animation-delay: 0.1s">
                        <div class="space-y-6">
                        
                            <div class="space-y-2">
                                <div class="flex items-center space-x-2">
                                    <div class="w-8 h-8 bg-gradient-to-br from-primary-100 to-primary-200 dark:from-primary-900 dark:to-primary-800 rounded-lg flex items-center justify-center">
                                        <i data-lucide="flag" class="w-4 h-4 text-primary-600 dark:text-primary-400"></i>
                                    </div>
                                    <p class="text-sm font-medium text-surface-600 dark:text-surface-400">Trip Name</p>
                                </div>
                                <h3 class="text-xl font-bold text-surface-800 dark:text-surface-200 ml-10">${journey.itinerary?.draftName || journey.itinerary?.name || 'Active Journey'}</h3>
                            </div>
                    
                            <div class="space-y-2">
                                <div class="flex items-center space-x-2">
                                    <div class="w-8 h-8 bg-gradient-to-br from-accent-100 to-accent-200 dark:from-accent-900 dark:to-accent-800 rounded-lg flex items-center justify-center">
                                        <i data-lucide="route" class="w-4 h-4 text-accent-600 dark:text-accent-400"></i>
                                    </div>
                                    <p class="text-sm font-medium text-surface-600 dark:text-surface-400">Destinations</p>
                                </div>
                                <div class="ml-10">
                                    <div class="flex flex-wrap gap-2">
                                        ${journey.itinerary?.destinations?.map((dest, index) => `
                                            <div class="flex items-center">
                                                <div class="px-3 py-1 bg-surface-100 dark:bg-surface-800 rounded-full text-sm text-surface-700 dark:text-surface-300">
                                                    📍 ${dest.city}
                                                </div>
                                                ${index < journey.itinerary.destinations.length - 1 ? '<i data-lucide="arrow-right" class="w-4 h-4 text-surface-400 mx-2"></i>' : ''}
                                            </div>
                                        `).join('') || '<div class="px-3 py-1 bg-surface-100 dark:bg-surface-800 rounded-full text-sm text-surface-700 dark:text-surface-300">📍 Adventure Locations</div>'}
                                    </div>
                                </div>
                            </div>
                        
                            <div class="space-y-2">
                                <div class="flex items-center space-x-2">
                                    <div class="w-8 h-8 bg-gradient-to-br from-primary-100 to-accent-100 dark:from-primary-900 dark:to-accent-900 rounded-lg flex items-center justify-center">
                                        <i data-lucide="users" class="w-4 h-4 text-primary-600 dark:text-primary-400"></i>
                                    </div>
                                    <p class="text-sm font-medium text-surface-600 dark:text-surface-400">Fellow Travelers</p>
                                </div>
                                <p class="text-surface-800 dark:text-surface-200 ml-10">${state.profile?.fullName || 'Unknown Traveler'} ${state.profile?.familyMembers?.length ? `(+${state.profile.familyMembers.length} Family Members)` : ''}</p>
                            </div>
                        </div>
                    </div>

                    <div class="space-y-4">
                        
                        <button onclick="showQrModal(state.activeJourneyData)" class="w-full bg-gradient-to-r from-primary-600 to-accent-600 hover:from-primary-700 hover:to-accent-700 text-white font-semibold py-4 px-6 rounded-2xl transition-all duration-300 transform hover:scale-105 hover:shadow-lg flex items-center justify-center animate-scale-in" style="animation-delay: 0.2s">
                            <div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center mr-3">
                                <i data-lucide="scan-line" class="w-6 h-6"></i>
                            </div>
                            <div class="text-left">
                                <div class="font-semibold">${t.showQrCode}</div>
                                <div class="text-xs opacity-90">Share your journey info</div>
                            </div>
                        </button>

                        <button onclick="handleCheckIn()" class="w-full bg-gradient-to-r from-green-500 to-emerald-600 hover:from-green-600 hover:to-emerald-700 text-white font-semibold py-4 px-6 rounded-2xl transition-all duration-300 transform hover:scale-105 hover:shadow-lg flex items-center justify-center animate-scale-in" style="animation-delay: 0.3s">
                            <div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center mr-3">
                                <i data-lucide="heart-handshake" class="w-6 h-6"></i>
                            </div>
                            <div class="text-left">
                                <div class="font-semibold">I'm Safe Check-in</div>
                                <div class="text-xs opacity-90">Update your safety status</div>
                            </div>
                        </button>

                        <button onclick="handleEndJourney()" class="w-full bg-gradient-to-r from-red-500 to-red-600 hover:from-red-600 hover:to-red-700 text-white font-semibold py-4 px-6 rounded-2xl transition-all duration-300 transform hover:scale-105 hover:shadow-lg flex items-center justify-center animate-scale-in" style="animation-delay: 0.4s">
                            <div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center mr-3">
                                <i data-lucide="square" class="w-6 h-6"></i>
                            </div>
                            <div class="text-left">
                                <div class="font-semibold">End Journey</div>
                                <div class="text-xs opacity-90">Complete your trip</div>
                            </div>
                        </button>
                    </div>
    
                    <div class="mt-6 bg-gradient-to-r from-green-50 to-emerald-50 dark:from-green-950 dark:to-emerald-950 p-4 rounded-2xl border border-green-200 dark:border-green-800 animate-fade-in" style="animation-delay: 0.5s">
                        <div class="flex items-center space-x-3">
                            <div class="w-10 h-10 bg-green-100 dark:bg-green-900 rounded-xl flex items-center justify-center">
                                <i data-lucide="shield-check" class="w-5 h-5 text-green-600 dark:text-green-400"></i>
                            </div>
                            <div>
                                <p class="font-semibold text-green-800 dark:text-green-200">Safety System Active</p>
                                <p class="text-sm text-green-600 dark:text-green-400">Real-time location monitoring enabled</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        `;
        lucide.createIcons();
        
       
        setTimeout(() => initializeJourneyMap(), 100);
    }

    

   

async function renderAccountPage() {
    const t = getT();
    
   
    const familyMembersHTML = state.profile?.familyMembers.map(m => `
        <div class="flex justify-between items-center bg-gray-50 dark:bg-gray-700 p-2 rounded-lg">
            <p>${m.fullName} (Age: ${m.age})</p>
            <button onclick="handleRemoveFamilyMember('${m._id}')" class="p-1 text-red-500 hover:bg-red-100 dark:hover:bg-red-900/50 rounded-full">
                <i data-lucide="trash-2" class="w-4 h-4"></i>
            </button>
        </div>
    `).join('') || '<p class="text-sm text-neutral-text dark:text-gray-400">No family members added yet.</p>';

    appContainer.innerHTML = `
        <div class="relative flex-grow overflow-hidden">
            <div class="absolute inset-0 opacity-10">
                <div class="absolute top-20 right-8 w-24 h-24 bg-primary-300 rounded-full animate-float"></div>
                <div class="absolute bottom-40 left-12 w-32 h-32 bg-accent-300 rounded-full animate-float" style="animation-delay: 2s"></div>
